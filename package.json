{
  "name": "codetrace-git",
  "displayName": "CodeTrace_Git",
  "description": "Git productivity features for VS Code powered by the local Git CLI.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "files": [
    "dist/**",
    "resources/**",
    "README.md",
    "LICENSE",
    "LICENSE.md"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:openGitInsight.fileHistory",
    "onView:openGitInsight.branches",
    "onCommand:openGitInsight.refreshFileHistory",
    "onCommand:openGitInsight.showCommitDetails",
    "onCommand:openGitInsight.compareWithPrevious"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openGitInsight",
          "title": "Open Git Insight",
          "icon": "resources/git.svg"
        }
      ]
    },
    "views": {
      "openGitInsight": [
        {
          "id": "openGitInsight.fileHistory",
          "name": "File History"
        },
        {
          "id": "openGitInsight.branches",
          "name": "Branches"
        }
      ]
    },
    "commands": [
      {
        "command": "openGitInsight.refreshFileHistory",
        "title": "Open Git Insight: Refresh File History"
      },
      {
        "command": "openGitInsight.showCommitDetails",
        "title": "Open Git Insight: Show Commit Details"
      },
      {
        "command": "openGitInsight.compareWithPrevious",
        "title": "Open Git Insight: Compare Current File With Previous Revision"
      },
      {
        "command": "openGitInsight.copyCommitHash",
        "title": "Open Git Insight: Copy Commit Hash"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "openGitInsight.refreshFileHistory",
          "when": "view == openGitInsight.fileHistory",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "openGitInsight.showCommitDetails",
          "when": "view == openGitInsight.fileHistory && viewItem == commit",
          "group": "inline"
        },
        {
          "command": "openGitInsight.compareWithPrevious",
          "when": "view == openGitInsight.fileHistory && viewItem == commit",
          "group": "inline"
        },
        {
          "command": "openGitInsight.copyCommitHash",
          "when": "view == openGitInsight.fileHistory && viewItem == commit",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "openGitInsight.compareWithPrevious",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Open Git Insight",
      "properties": {
        "openGitInsight.inlineBlame.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline blame annotations."
        },
        "openGitInsight.inlineBlame.mode": {
          "type": "string",
          "enum": [
            "currentLine",
            "allLines"
          ],
          "default": "currentLine",
          "description": "Show blame only for the active line or for all visible lines."
        },
        "openGitInsight.history.maxCommits": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of history entries to load for the active file."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node ./scripts/package-vsix.js"
  },
  "devDependencies": {
    "@types/node": "^12.20.55",
    "@types/vscode": "^1.90.0",
    "cheerio": "1.0.0-rc.12",
    "typescript": "4.9.5",
    "vsce": "1.103.1"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}
